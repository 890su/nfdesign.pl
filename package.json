{
  "name": "need-for-design-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=22.12.0 <25"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "build:cloudflare": "cross-env CF_RUNTIME=1 PUBLIC_SITE_URL=https://nfdesign.pl astro check && cross-env CF_RUNTIME=1 PUBLIC_SITE_URL=https://nfdesign.pl astro build",
    "preview": "astro build && node ./dist/server/entry.mjs",
    "check": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:local": "wrangler d1 execute need-for-design-leads --local --file=./migrations/0001_init.sql",
    "deploy": "cross-env CF_RUNTIME=1 PUBLIC_SITE_URL=https://nfdesign.pl astro build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.7.0",
    "@astrojs/node": "10.0.6",
    "@astrojs/sitemap": "3.7.3",
    "@fontsource-variable/unbounded": "5.2.8",
    "@tailwindcss/vite": "4.3.2",
    "astro": "6.3.8",
    "tailwindcss": "4.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.6",
    "cross-env": "10.0.0",
    "prettier": "3.6.2",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "5.9.3",
    "wrangler": "4.110.0"
  }
}
