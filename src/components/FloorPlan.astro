---
interface Props {
  segment: "new_build" | "small_flat" | "rental";
  before: string;
  after: string;
  disclaimer: string;
}
const { segment, before, after, disclaimer } = Astro.props;
const accent =
  segment === "rental"
    ? "#b9563c"
    : segment === "small_flat"
      ? "#0c514d"
      : "#b9563c";
---

<div class="plan-card" data-plan-card>
  <div class="plan-toolbar">
    <span class="mono">42.8 m² / concept</span>
    <div class="plan-tabs" role="group" aria-label={`${before} / ${after}`}>
      <button
        class="plan-tab"
        type="button"
        aria-pressed="true"
        data-plan-tab="before">{before}</button
      >
      <button
        class="plan-tab"
        type="button"
        aria-pressed="false"
        data-plan-tab="after">{after}</button
      >
    </div>
  </div>
  <div class="plan-view" data-plan-view="before">
    <svg viewBox="0 0 720 470" role="img" aria-label={before}>
      <rect
        x="55"
        y="45"
        width="610"
        height="360"
        fill="none"
        stroke="#17201d"
        stroke-width="7"></rect>
      <path
        d="M290 48v165H58M290 213h205M495 48v165M495 213v192M290 213v192"
        fill="none"
        stroke="#17201d"
        stroke-width="5"></path>
      <path
        d="M55 310h100M155 405V310M495 315h170"
        fill="none"
        stroke="#17201d"
        stroke-width="5"></path>
      <path
        d="M290 150a63 63 0 0 0-63 63M495 150a63 63 0 0 1 63 63M290 330a74 74 0 0 0-74 74"
        fill="none"
        stroke="#7e8984"
        stroke-width="2"
        stroke-dasharray="7 7"></path>
      <g fill="#d8d2c5" stroke="#7e8984" stroke-width="2">
        <rect x="82" y="78" width="155" height="78"></rect>
        <rect x="326" y="76" width="118" height="54"></rect>
        <rect x="526" y="72" width="105" height="90"></rect>
        <rect x="333" y="262" width="105" height="54"></rect>
        <circle cx="605" cy="360" r="28"></circle>
      </g>
      <g fill="#53605b" font-family="system-ui" font-size="14">
        <text x="82" y="190">room 01</text><text x="326" y="190">room 02</text
        ><text x="526" y="190">bath</text><text x="330" y="375">living?</text>
      </g>
      <g stroke="#b9563c" stroke-width="2"
        ><path d="M328 335l95-95"></path><path d="M423 335l-95-95"
        ></path><circle cx="605" cy="360" r="48" fill="none"></circle></g
      >
    </svg>
  </div>
  <div class="plan-view" data-plan-view="after" hidden>
    <svg viewBox="0 0 720 470" role="img" aria-label={after}>
      <rect
        x="55"
        y="45"
        width="610"
        height="360"
        fill="none"
        stroke="#17201d"
        stroke-width="7"></rect>
      <path
        d="M290 48v165H58M290 213h205M495 48v165M495 213v192M290 213v192"
        fill="none"
        stroke="#17201d"
        stroke-width="5"></path>
      <path
        d="M55 310h100M155 405V310M495 315h170"
        fill="none"
        stroke="#17201d"
        stroke-width="5"></path>
      <g fill="#ded9cd" stroke="#53605b" stroke-width="2">
        <rect x="78" y="71" width="175" height="78" rx="3"></rect>
        <rect x="83" y="335" width="52" height="55"></rect>
        <rect x="315" y="70" width="155" height="42"></rect>
        <rect x="315" y="127" width="64" height="44"></rect>
        <rect x="522" y="70" width="110" height="105"></rect>
        <rect x="325" y="263" width="148" height="76" rx="4"></rect>
        <rect x="330" y="355" width="134" height="28"></rect>
        <ellipse cx="577" cy="355" rx="56" ry="31"></ellipse>
      </g>
      <g fill="none" stroke={accent} stroke-width="3">
        <path d="M137 320V236H85"></path><circle
          cx="137"
          cy="320"
          r="6"
          fill={accent}></circle>
        <path d="M399 254V221h90"></path><circle
          cx="399"
          cy="254"
          r="6"
          fill={accent}></circle>
        <path d="M577 315v-82h65"></path><circle
          cx="577"
          cy="315"
          r="6"
          fill={accent}></circle>
      </g>
      <g fill={accent} font-family="system-ui" font-size="13" font-weight="700">
        <text x="76" y="230">01 storage</text><text x="493" y="225"
          >02 flexible table</text
        ><text x="544" y="225">03 focus zone</text>
      </g>
      <g stroke="#53605b" stroke-width="1"
        ><path d="M55 427h610"></path><path d="M55 419v16M665 419v16"></path></g
      >
      <text
        x="330"
        y="448"
        text-anchor="middle"
        fill="#53605b"
        font-family="system-ui"
        font-size="12">8 420 mm</text
      >
    </svg>
  </div>
  <p class="disclaimer plan-disclaimer">
    {disclaimer}
  </p>
</div>
