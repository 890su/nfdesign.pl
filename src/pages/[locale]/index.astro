---
export const prerender = true;
export function getStaticPaths() {
  return [
    { params: { locale: "pl" }, props: { href: "/pl/nowe-mieszkanie/" } },
    { params: { locale: "uk" }, props: { href: "/uk/novobudova/" } },
    { params: { locale: "ru" }, props: { href: "/ru/novostroyka/" } },
  ];
}
return Astro.redirect(Astro.props.href, 302);
---
