---
import StrategyLayout from "@/layouts/StrategyLayout.astro";
import {
  getStrategyDocument,
  strategyDocuments,
} from "@/data/strategy-documents";
import { getDocumentHeadings, renderMarkdown } from "@/lib/markdown";

export const prerender = true;

export function getStaticPaths() {
  return strategyDocuments.map((document) => ({
    params: { slug: document.slug },
  }));
}

const document = getStrategyDocument(Astro.params.slug ?? "");
if (!document) return Astro.redirect("/strategy/", 302);

const headings = getDocumentHeadings(document.content);
const renderedDocument = renderMarkdown(document.content);
---

<StrategyLayout
  title={`${document.title} · Strategy · Need for Design`}
  description={document.subtitle}
>
  <section class="strategy-document-hero">
    <div class="strategy-shell">
      <a class="strategy-back" href="/strategy/"
        ><span aria-hidden="true">←</span> Все материалы</a
      >
      <p class="strategy-document-source">{document.source}</p>
      <h1>{document.title}</h1>
      <p>{document.subtitle}</p>
    </div>
  </section>

  <div class="strategy-shell strategy-reading-layout">
    <aside class="strategy-toc" aria-label="Содержание документа">
      <p>Содержание</p>
      <ol>
        {
          headings
            .filter((heading) => heading.depth > 1)
            .map((heading) => (
              <li class:list={{ "is-subsection": heading.depth === 3 }}>
                <a href={`#${heading.id}`}>{heading.text}</a>
              </li>
            ))
        }
      </ol>
    </aside>
    <article class="strategy-prose" set:html={renderedDocument} />
  </div>
</StrategyLayout>

<style>
  .strategy-document-hero {
    padding: clamp(4rem, 8vw, 7rem) 0 clamp(2.5rem, 5vw, 4.5rem);
    border-bottom: 2px solid var(--strategy-ink);
    background: linear-gradient(
        90deg,
        transparent calc(100% - 1px),
        rgba(21, 69, 216, 0.1) 1px
      )
      0 0 / min(8.333vw, 8rem) 100%;
  }
  .strategy-back {
    display: inline-flex;
    gap: 0.65rem;
    color: var(--strategy-blue);
    font-size: 0.7rem;
    font-weight: 750;
    letter-spacing: 0.1em;
    text-decoration: none;
    text-transform: uppercase;
  }
  .strategy-back:hover {
    text-decoration: underline;
    text-underline-offset: 0.25em;
  }
  .strategy-document-source {
    margin: clamp(2.5rem, 5vw, 4.5rem) 0 1rem;
    color: var(--strategy-red);
    font-size: 0.7rem;
    font-weight: 750;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  h1 {
    max-width: 18ch;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5.5vw, 5.8rem);
    font-weight: 530;
    letter-spacing: -0.06em;
    line-height: 0.98;
  }
  .strategy-document-hero p:last-child {
    max-width: 60ch;
    margin: 1.5rem 0 0;
    color: rgba(17, 21, 22, 0.72);
    font-size: clamp(1rem, 1.4vw, 1.2rem);
  }
  .strategy-reading-layout {
    display: grid;
    grid-template-columns: minmax(12rem, 0.32fr) minmax(0, 0.68fr);
    gap: clamp(2.5rem, 8vw, 9rem);
    padding: clamp(3rem, 6vw, 6rem) 0 clamp(5rem, 10vw, 10rem);
  }
  .strategy-toc {
    position: sticky;
    top: 1.5rem;
    align-self: start;
    padding-top: 0.2rem;
  }
  .strategy-toc > p {
    margin: 0 0 1rem;
    color: var(--strategy-red);
    font-size: 0.68rem;
    font-weight: 750;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .strategy-toc ol {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--strategy-line);
  }
  .strategy-toc li {
    border-bottom: 1px solid var(--strategy-line);
  }
  .strategy-toc a {
    display: block;
    padding: 0.6rem 0;
    color: rgba(17, 21, 22, 0.72);
    font-size: 0.76rem;
    line-height: 1.35;
    text-decoration: none;
  }
  .strategy-toc a:hover {
    color: var(--strategy-blue);
  }
  .strategy-toc .is-subsection a {
    padding-left: 0.75rem;
    font-size: 0.7rem;
  }
  .strategy-prose {
    min-width: 0;
    font-size: clamp(1rem, 1.1vw, 1.12rem);
    line-height: 1.7;
  }
  .strategy-prose :global(h1),
  .strategy-prose :global(h2),
  .strategy-prose :global(h3) {
    scroll-margin-top: 1.5rem;
    font-family: var(--font-display);
    font-weight: 540;
    letter-spacing: -0.045em;
    line-height: 1.14;
  }
  .strategy-prose :global(h1) {
    margin: 0 0 2rem;
    font-size: clamp(2rem, 3vw, 3.2rem);
  }
  .strategy-prose :global(h2) {
    margin: 4rem 0 1.25rem;
    padding-top: 0.9rem;
    border-top: 2px solid var(--strategy-ink);
    font-size: clamp(1.45rem, 2.4vw, 2.3rem);
  }
  .strategy-prose :global(h3) {
    margin: 2.3rem 0 0.85rem;
    font-size: clamp(1.1rem, 1.7vw, 1.45rem);
  }
  .strategy-prose :global(p) {
    margin: 0 0 1.35rem;
  }
  .strategy-prose :global(a) {
    color: var(--strategy-blue);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }
  .strategy-prose :global(ul),
  .strategy-prose :global(ol) {
    margin: 0 0 1.55rem;
    padding-left: 1.25rem;
  }
  .strategy-prose :global(li) {
    margin: 0.45rem 0;
    padding-left: 0.25rem;
  }
  .strategy-prose :global(.task-item) {
    display: flex;
    gap: 0.65rem;
    align-items: flex-start;
    list-style: none;
    margin-left: -1.25rem;
  }
  .strategy-prose :global(.task-item input) {
    width: 1rem;
    height: 1rem;
    margin-top: 0.38rem;
    accent-color: var(--strategy-blue);
  }
  .strategy-prose :global(blockquote) {
    margin: 2rem 0;
    padding: 0.25rem 0 0.25rem 1.25rem;
    border-left: 3px solid var(--strategy-red);
    color: rgba(17, 21, 22, 0.76);
  }
  .strategy-prose :global(blockquote p) {
    margin: 0;
  }
  .strategy-prose :global(code) {
    padding: 0.1em 0.35em;
    background: rgba(21, 69, 216, 0.1);
    font-size: 0.85em;
  }
  .strategy-prose :global(pre) {
    overflow-x: auto;
    margin: 2rem 0;
    padding: 1.25rem;
    background: var(--strategy-ink);
    color: #f3f4ef;
    font-size: 0.82rem;
    line-height: 1.55;
  }
  .strategy-prose :global(pre code) {
    padding: 0;
    background: none;
  }
  .strategy-prose :global(hr) {
    margin: 3rem 0;
    border: 0;
    border-top: 1px solid var(--strategy-line);
  }
  .strategy-prose :global(.table-wrap) {
    overflow-x: auto;
    margin: 2rem 0;
  }
  .strategy-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
  }
  .strategy-prose :global(th),
  .strategy-prose :global(td) {
    min-width: 8rem;
    padding: 0.7rem;
    border: 1px solid var(--strategy-line);
    text-align: left;
    vertical-align: top;
  }
  .strategy-prose :global(th) {
    background: rgba(21, 69, 216, 0.08);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
  }
  @media (max-width: 800px) {
    .strategy-reading-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .strategy-toc {
      position: static;
    }
    .strategy-toc ol {
      columns: 2;
      column-gap: 1.5rem;
    }
    .strategy-toc li {
      break-inside: avoid;
    }
  }
  @media (max-width: 520px) {
    .strategy-toc ol {
      columns: 1;
    }
    .strategy-prose :global(h2) {
      margin-top: 3rem;
    }
  }
</style>
